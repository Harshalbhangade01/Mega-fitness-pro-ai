@{
    var trainers = ViewBag.Trainers as List<User>;
    var messages = ViewBag.Messages as List<ChatMessage>;
    int myId = Context.Session.GetInt32("uid") ?? 0;

    // Serialize messages to JSON for JS filtering
    var msgsJson = System.Text.Json.JsonSerializer.Serialize(
        (messages ?? new List<ChatMessage>()).Select(m => new {
            senderId = m.SenderId,
            receiverId = m.ReceiverId,
            message = m.Message,
            senderName = m.SenderName,
            time = m.SentAt.ToString("hh:mm tt")
        })
    );
}
<div class="row mb-4">
    <div class="col"><h4 class="fw-bold mb-0"><i class="fas fa-comments me-2" style="color:#f39c12"></i>Chat with Trainers</h4></div>
</div>
<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card h-100">
            <div class="card-header py-3"><h6 class="mb-0 fw-bold">Trainers</h6></div>
            <div class="card-body p-0">
                @foreach(var t in trainers ?? new List<User>()){
                    <a href="#" onclick="selectTrainer(@t.Id, '@t.Name')" class="d-flex align-items-center p-3 border-bottom trainer-item" style="text-decoration:none;color:#e0e0e0;transition:.2s" id="trainer-@t.Id">
                        <div style="width:40px;height:40px;background:linear-gradient(135deg,#f39c12,#e67e22);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#111;font-weight:700;flex-shrink:0">@t.Name[0]</div>
                        <div class="ms-3"><div class="fw-bold">@t.Name</div><small class="text-muted">@t.Specialization</small></div>
                    </a>
                }
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header py-3 d-flex align-items-center" id="chatHeader">
                <h6 class="mb-0 fw-bold text-muted">Select a trainer to chat</h6>
            </div>
            <div class="card-body p-3">
                <div class="chat-box" id="chatBox">
                    <div class="text-center text-muted mt-5" id="placeholderMsg">
                        <i class="fas fa-comments fa-3x mb-3 d-block"></i>Select a trainer to view conversation
                    </div>
                </div>
            </div>
            <div class="card-footer p-3">
                <form method="post" action="/User/SendMessage" id="msgForm">
                    <input type="hidden" name="receiverId" id="receiverId" value="0"/>
                    <div class="d-flex gap-2">
                        <input type="text" name="message" class="form-control" placeholder="Type your message..." id="msgInput" autocomplete="off" required/>
                        <button type="submit" class="btn btn-primary px-4"><i class="fas fa-paper-plane"></i></button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
<script>
var allMessages = @Html.Raw(msgsJson);
var myId = @myId;

function selectTrainer(id, name) {
    // Set correct receiver ID
    document.getElementById('receiverId').value = id;

    // Update header
    document.getElementById('chatHeader').innerHTML =
        '<div style="width:35px;height:35px;background:linear-gradient(135deg,#f39c12,#e67e22);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#111;font-weight:700">' +
        name[0] + '</div><h6 class="mb-0 fw-bold ms-2">' + name + '</h6>';

    // Highlight selected trainer
    document.querySelectorAll('.trainer-item').forEach(el => el.style.background = 'transparent');
    document.getElementById('trainer-' + id).style.background = 'rgba(243,156,18,.1)';

    // Filter messages - only between current user and this specific trainer
    var filtered = allMessages.filter(m =>
        (m.senderId == myId && m.receiverId == id) ||
        (m.senderId == id && m.receiverId == myId)
    );

    var chatBox = document.getElementById('chatBox');
    chatBox.innerHTML = '';

    if (filtered.length === 0) {
        chatBox.innerHTML = '<div class="text-center text-muted mt-5"><i class="fas fa-comments fa-3x mb-3 d-block"></i>No messages yet. Start a conversation!</div>';
    } else {
        filtered.forEach(function(m) {
            if (m.senderId == myId) {
                chatBox.innerHTML +=
                    '<div class="d-flex flex-column align-items-end">' +
                    '<div class="msg-sent">' + escHtml(m.message) +
                    '<div class="msg-time text-end">' + m.time + '</div></div></div>';
            } else {
                chatBox.innerHTML +=
                    '<div class="d-flex flex-column align-items-start">' +
                    '<small class="text-muted mb-1 ms-1">' + escHtml(m.senderName) + '</small>' +
                    '<div class="msg-recv">' + escHtml(m.message) +
                    '<div class="msg-time">' + m.time + '</div></div></div>';
            }
        });
    }
    chatBox.scrollTop = chatBox.scrollHeight;
}


// Auto-select trainer after sending message (page reload ke baad)
var autoSelectId = @(ViewBag.SelectedTrainerId ?? 0);
var autoSelectName = '';
if (autoSelectId > 0) {
    var el = document.getElementById('trainer-' + autoSelectId);
    if (el) {
        autoSelectName = el.querySelector('.fw-bold') ? el.querySelector('.fw-bold').innerText : '';
        selectTrainer(autoSelectId, autoSelectName);
    }
}

function escHtml(t) {
    if (!t) return '';
    return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
}