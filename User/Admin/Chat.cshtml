@{
    var users = ViewBag.Users as List<User>;
    var messages = ViewBag.Messages as List<ChatMessage>;
    int myId = Context.Session.GetInt32("uid") ?? 0;
    int selectedUserId = ViewBag.SelectedUserId ?? 0;
    string selectedUserName = "";
    if (selectedUserId > 0) {
        selectedUserName = (users ?? new List<User>()).FirstOrDefault(u => u.Id == selectedUserId)?.Name ?? "";
    }
}
<div class="row mb-4">
    <div class="col"><h4 class="fw-bold mb-0"><i class="fas fa-comments me-2" style="color:#f39c12"></i>Messages</h4></div>
</div>
<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-header py-3"><h6 class="mb-0 fw-bold">Members</h6></div>
            <div class="card-body p-0">
                @foreach(var u in users ?? new List<User>()){
                    string activeStyle = (u.Id == selectedUserId) ? "background:rgba(243,156,18,.1);" : "";
                    <a href="/Admin/Chat?userId=@u.Id" class="d-flex align-items-center p-3 border-bottom user-item" style="text-decoration:none;color:#e0e0e0;@activeStyle" id="user-@u.Id">
                        <div style="width:40px;height:40px;background:#2a2a4a;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0">@u.Name[0]</div>
                        <div class="ms-3"><div class="fw-bold">@u.Name</div><small class="text-muted">@u.Email</small></div>
                    </a>
                }
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header py-3 d-flex align-items-center" id="chatHeader">
                @if(selectedUserId > 0 && !string.IsNullOrEmpty(selectedUserName)){
                    <div style="width:35px;height:35px;background:#2a2a4a;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700">@selectedUserName[0]</div>
                    <h6 class="mb-0 fw-bold ms-2">@selectedUserName</h6>
                } else {
                    <h6 class="mb-0 fw-bold text-muted">Select a member to chat</h6>
                }
            </div>
            <div class="card-body p-3">
                <div class="chat-box" id="chatBox">
                    @if(messages != null && messages.Any()){
                        @foreach(var m in messages){
                            if(m.SenderId == myId){
                                <div class="d-flex flex-column align-items-end"><div class="msg-sent">@m.Message<div class="msg-time text-end">@m.SentAt.ToString("hh:mm tt")</div></div></div>
                            } else {
                                <div class="d-flex flex-column align-items-start"><small class="text-muted mb-1 ms-1">@m.SenderName</small><div class="msg-recv">@m.Message<div class="msg-time">@m.SentAt.ToString("hh:mm tt")</div></div></div>
                            }
                        }
                    } else {
                        <div class="text-center text-muted mt-5"><i class="fas fa-comments fa-3x mb-3 d-block"></i>@(selectedUserId > 0 ? "No messages yet" : "Select a member to chat")</div>
                    }
                </div>
            </div>
            @if(selectedUserId > 0){
            <div class="card-footer p-3">
                <form method="post" action="/Admin/SendMessage">
                    <input type="hidden" name="receiverId" value="@selectedUserId"/>
                    <div class="d-flex gap-2">
                        <input type="text" name="message" class="form-control" placeholder="Type message..." autocomplete="off" required/>
                        <button type="submit" class="btn btn-primary px-4"><i class="fas fa-paper-plane"></i></button>
                    </div>
                </form>
            </div>
            }
        </div>
    </div>
</div>
@section Scripts {
<script>
var cb=document.getElementById('chatBox'); if(cb) cb.scrollTop=cb.scrollHeight;
</script>
}
