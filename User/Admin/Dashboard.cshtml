@{
    var users = ViewBag.Users as List<User>;
    var plans = ViewBag.Plans as List<Plan>;
    var userPlans = ViewBag.UserPlans as List<UserPlan>;
    var bookings = ViewBag.Bookings as List<TrainerBooking>;
    var trainers = ViewBag.Trainers as List<User>;
    var payments = ViewBag.Payments as List<Payment>;
    var attendances = ViewBag.Attendances as List<Attendance>;
}
<div class="row mb-4">
    <div class="col"><h4 class="fw-bold mb-0">Admin <span style="color:#f39c12">Dashboard</span></h4><small class="text-muted">Full system overview</small></div>
    <div class="col-auto"><a href="/Admin/Chat" class="btn btn-outline-warning"><i class="fas fa-comments me-2"></i>Messages</a></div>
</div>

<!-- Stats -->
<div class="row mb-4">
    <div class="col-md-3 col-6 mb-3">
        <div class="stat-card"><div class="stat-icon" style="background:rgba(52,152,219,.2)"><i class="fas fa-users" style="color:#3498db"></i></div><h2 class="fw-bold mb-0" style="color:#3498db">@(ViewBag.TotalUsers ?? 0)</h2><small class="text-muted">Total Members</small></div>
    </div>
    <div class="col-md-3 col-6 mb-3">
        <div class="stat-card"><div class="stat-icon" style="background:rgba(39,174,96,.2)"><i class="fas fa-rupee-sign" style="color:#27ae60"></i></div><h2 class="fw-bold mb-0" style="color:#27ae60">₹@(ViewBag.TotalRevenue ?? 0)</h2><small class="text-muted">Total Revenue</small></div>
    </div>
    <div class="col-md-3 col-6 mb-3">
        <div class="stat-card"><div class="stat-icon" style="background:rgba(243,156,18,.2)"><i class="fas fa-calendar-check" style="color:#f39c12"></i></div><h2 class="fw-bold mb-0" style="color:#f39c12">@(ViewBag.TodayAttendance ?? 0)</h2><small class="text-muted">Today's Attendance</small></div>
    </div>
    <div class="col-md-3 col-6 mb-3">
        <div class="stat-card"><div class="stat-icon" style="background:rgba(155,89,182,.2)"><i class="fas fa-user-tie" style="color:#9b59b6"></i></div><h2 class="fw-bold mb-0" style="color:#9b59b6">@(ViewBag.TotalBookings ?? 0)</h2><small class="text-muted">Trainer Bookings</small></div>
    </div>
</div>

<!-- Recent Payments -->
<div class="card mb-4">
    <div class="card-header py-3"><h6 class="mb-0 fw-bold"><i class="fas fa-receipt me-2" style="color:#f39c12"></i>Recent Payments</h6></div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead><tr><th>User ID</th><th>Plan</th><th>Amount</th><th>Method</th><th>Transaction</th><th>Date</th><th>Status</th></tr></thead>
                <tbody>
                    @if(payments != null && payments.Count > 0){
                        @foreach(var p in payments){
                            var planName = plans?.FirstOrDefault(x=>x.Id==p.PlanId)?.PlanName ?? "N/A";
                            <tr>
                                <td>@p.UserId</td>
                                <td>@planName</td>
                                <td><strong style="color:#27ae60">₹@p.Amount</strong></td>
                                <td><span class="badge bg-secondary">@p.PaymentMethod</span></td>
                                <td><small class="text-muted">@p.TransactionId</small></td>
                                <td>@p.PaymentDate.ToString("dd MMM yy")</td>
                                <td><span class="badge bg-success">@p.Status</span></td>
                            </tr>
                        }
                    } else { <tr><td colspan="7" class="text-center text-muted py-3">No payments yet</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Members & Attendance side by side -->
<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="fas fa-user-tie me-2" style="color:#f39c12"></i>Trainers <span class="badge bg-warning text-dark ms-1">@(trainers?.Count ?? 0)</span></h6>
                <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#addTrainerModal">
                    <i class="fas fa-plus me-1"></i>Add Trainer
                </button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0" style="color:#e0e0e0">
                        <thead style="background:#1a1a2e"><tr><th>Name</th><th>Specialization</th><th>Rate</th><th>Email</th><th>Action</th></tr></thead>
                        <tbody>
                            @if(trainers != null && trainers.Count > 0){
                                @foreach(var t in trainers){
                                    <tr>
                                        <td><div class="d-flex align-items-center gap-2"><div style="width:28px;height:28px;background:linear-gradient(135deg,#f39c12,#e67e22);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;color:#111">@t.Name[0]</div>@t.Name</div></td>
                                        <td><small>@t.Specialization</small></td>
                                        <td><small style="color:#f39c12">₹@t.HourlyRate/hr</small></td>
                                        <td><small class="text-muted">@t.Email</small></td>
                                        <td><a href="/Admin/DeleteTrainer/@t.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete trainer?')"><i class="fas fa-trash"></i></a></td>
                                    </tr>
                                }
                            } else { <tr><td colspan="5" class="text-center text-muted py-3">No trainers yet</td></tr> }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header py-3"><h6 class="mb-0 fw-bold"><i class="fas fa-users me-2" style="color:#f39c12"></i>Members</h6></div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead><tr><th>Name</th><th>Email</th><th>Joined</th></tr></thead>
                        <tbody>
                            @if(users != null && users.Count > 0){
                                @foreach(var u in users){
                                    <tr><td><i class="fas fa-user me-2 text-primary"></i>@u.Name</td><td class="small text-muted">@u.Email</td><td class="small">@u.JoinDate.ToString("dd MMM")</td></tr>
                                }
                            } else { <tr><td colspan="3" class="text-center text-muted py-3">No members yet</td></tr> }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Attendance -->
<div class="card mb-4">
    <div class="card-header py-3"><h6 class="mb-0 fw-bold"><i class="fas fa-calendar me-2" style="color:#f39c12"></i>Recent Attendance</h6></div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead><tr><th>User ID</th><th>Check In</th><th>Check Out</th></tr></thead>
                <tbody>
                    @if(attendances != null && attendances.Count > 0){
                        @foreach(var a in attendances){
                            <tr><td>@a.UserId</td><td class="small">@a.CheckIn.ToString("dd MMM hh:mm tt")</td><td class="small">@(a.CheckOut.HasValue ? a.CheckOut.Value.ToString("hh:mm tt") : "--")</td></tr>
                        }
                    } else { <tr><td colspan="3" class="text-center text-muted py-3">No attendance yet</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Trainer Modal -->
<div class="modal fade" id="addTrainerModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="background:#16213e;color:#e0e0e0;border:1px solid #2a2a4a">
            <div class="modal-header" style="border-color:#2a2a4a">
                <h5 class="modal-title fw-bold"><i class="fas fa-user-plus me-2" style="color:#f39c12"></i>Add New Trainer</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Admin/AddTrainer">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6"><label class="form-label small">Full Name *</label><input name="name" type="text" class="form-control" required placeholder="e.g. Rahul Sharma"/></div>
                        <div class="col-md-6"><label class="form-label small">Email *</label><input name="email" type="email" class="form-control" required placeholder="trainer@email.com"/></div>
                        <div class="col-md-6"><label class="form-label small">Password *</label><input name="password" type="password" class="form-control" required placeholder="Login password"/></div>
                        <div class="col-md-6"><label class="form-label small">Phone *</label><input name="phone" type="text" class="form-control" required placeholder="9876543210"/></div>
                        <div class="col-md-6"><label class="form-label small">Specialization *</label><input name="specialization" type="text" class="form-control" required placeholder="e.g. Weight Loss"/></div>
                        <div class="col-md-6"><label class="form-label small">Hourly Rate (₹) *</label><input name="hourlyRate" type="number" class="form-control" required placeholder="500"/></div>
                        <div class="col-12"><label class="form-label small">Bio</label><textarea name="bio" class="form-control" rows="2" placeholder="Brief experience description..."></textarea></div>
                    </div>
                </div>
                <div class="modal-footer" style="border-color:#2a2a4a">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning"><i class="fas fa-plus me-1"></i>Add Trainer</button>
                </div>
            </form>
        </div>
    </div>
</div>
