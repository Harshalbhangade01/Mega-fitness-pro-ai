@{
    var progress = ViewBag.LatestProgress as ProgressRecord;
    var attendanceCount = (int)(ViewBag.AttendanceCount ?? 0);
    var myPlans = ViewBag.MyPlans as List<UserPlan>;
    string bmiCategory = "";
    string planStatus = myPlans != null && myPlans.Count > 0 ? "Active" : "None";

    if (progress != null)
    {
        if (progress.BMI < 18.5) bmiCategory = "Underweight";
        else if (progress.BMI < 25) bmiCategory = "Normal";
        else if (progress.BMI < 30) bmiCategory = "Overweight";
        else bmiCategory = "Obese";
    }
}

<div class="row mb-4">
    <div class="col">
        <h4 class="fw-bold mb-0"><i class="fas fa-robot me-2" style="color:#f39c12"></i>AI Fitness <span style="color:#f39c12">Tips</span></h4>
        <small class="text-muted">Personalized tips powered by Claude AI</small>
    </div>
</div>

<!-- User Stats Summary -->
<div class="row mb-4">
    <div class="col-md-4 mb-3">
        <div class="stat-card text-center">
            <div class="stat-icon mx-auto" style="background:rgba(243,156,18,.2)"><i class="fas fa-weight" style="color:#f39c12"></i></div>
            <h4 class="fw-bold" style="color:#f39c12">@(progress != null ? progress.BMI.ToString() : "--")</h4>
            <small class="text-muted">Your BMI @(bmiCategory != "" ? "· " + bmiCategory : "")</small>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="stat-card text-center">
            <div class="stat-icon mx-auto" style="background:rgba(39,174,96,.2)"><i class="fas fa-calendar-check" style="color:#27ae60"></i></div>
            <h4 class="fw-bold" style="color:#27ae60">@attendanceCount</h4>
            <small class="text-muted">Total Gym Visits</small>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="stat-card text-center">
            <div class="stat-icon mx-auto" style="background:rgba(155,89,182,.2)"><i class="fas fa-id-card" style="color:#9b59b6"></i></div>
            <h4 class="fw-bold" style="color:#9b59b6">@planStatus</h4>
            <small class="text-muted">Membership</small>
        </div>
    </div>
</div>

<!-- AI Chat Box -->
<div class="card mb-4">
    <div class="card-header py-3 d-flex align-items-center gap-2">
        <div style="width:38px;height:38px;background:linear-gradient(135deg,#f39c12,#e67e22);border-radius:50%;display:flex;align-items:center;justify-content:center">
            <i class="fas fa-robot" style="color:#1a1a1a"></i>
        </div>
        <div>
            <h6 class="mb-0 fw-bold">FitBot AI</h6>
            <small class="text-muted" style="font-size:.7rem">Powered by Claude</small>
        </div>
        <span class="ms-auto badge bg-success">Online</span>
    </div>
    <div class="card-body p-0">
        <!-- Chat Messages Area -->
        <div id="chatArea" style="height:420px;overflow-y:auto;padding:20px;background:#0d1117;">
            <!-- Welcome message -->
            <div class="d-flex align-items-start mb-4" id="welcomeMsg">
                <div style="width:36px;height:36px;background:linear-gradient(135deg,#f39c12,#e67e22);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                    <i class="fas fa-robot" style="color:#1a1a1a" style="font-size:.8rem"></i>
                </div>
                <div class="ms-3" style="max-width:80%">
                    <div style="background:#1a1a2e;border:1px solid #2a2a4a;border-radius:14px 14px 14px 4px;padding:14px 18px;">
                        <p class="mb-2">👋 Namaste <strong style="color:#f39c12">@ViewBag.UserName</strong>! Main hoon <strong>FitBot</strong> — tera personal AI fitness coach!</p>
                        @if (progress != null)
                        {
                            <p class="mb-2">Mujhe pata hai ki tera weight <strong style="color:#f39c12">@progress.Weight kg</strong> hai aur BMI <strong style="color:#f39c12">@progress.BMI</strong> (<strong>@bmiCategory</strong>) hai.</p>
                        }
                        <p class="mb-0">Neeche koi bhi fitness sawal poochho ya quick tip buttons use karo! 💪</p>
                    </div>
                    <small class="text-muted ms-2" style="font-size:.7rem">FitBot · Just now</small>
                </div>
            </div>
        </div>

        <!-- Quick Tip Buttons -->
        <div style="padding:12px 20px;border-top:1px solid #2a2a4a;background:#1a1a2e;">
            <small class="text-muted d-block mb-2">Quick Questions:</small>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-sm btn-outline-warning" onclick="askQuestion('Mujhe weight loss ke liye best workout routine batao')">🔥 Weight Loss</button>
                <button class="btn btn-sm btn-outline-warning" onclick="askQuestion('Muscle building ke liye diet plan kya hona chahiye?')">💪 Muscle Building</button>
                <button class="btn btn-sm btn-outline-warning" onclick="askQuestion('Beginner ke liye gym mein kya karna chahiye?')">🏋️ Beginner Tips</button>
                <button class="btn btn-sm btn-outline-warning" onclick="askQuestion('Post workout recovery ke liye kya karna chahiye?')">😴 Recovery</button>
                <button class="btn btn-sm btn-outline-warning" onclick="askQuestion('Healthy Indian diet plan batao fitness ke liye')">🥗 Diet Plan</button>
                @if (progress != null)
                {
                    <button class="btn btn-sm btn-outline-warning" onclick="askQuestion('Mera BMI @progress.BMI hai jo @bmiCategory category mein hai. Mujhe kya karna chahiye improve karne ke liye?')">📊 My BMI Analysis</button>
                }
            </div>
        </div>

        <!-- Input Area -->
        <div style="padding:15px 20px;border-top:1px solid #2a2a4a;background:#16213e;">
            <div class="d-flex gap-2">
                <input type="text" id="userInput" class="form-control" placeholder="Fitness ke baare mein kuch bhi poochho..." autocomplete="off"
                    onkeypress="if(event.key==='Enter') sendMessage()"/>
                <button class="btn btn-primary px-4" onclick="sendMessage()" id="sendBtn">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var userBMI = '@(progress?.BMI.ToString() ?? "unknown")';
    var userWeight = '@(progress?.Weight.ToString() ?? "unknown")';
    var userVisits = '@attendanceCount';
    var userName = '@ViewBag.UserName';
    var bmiCategory = '@bmiCategory';
    var planStatus = '@planStatus';

    function askQuestion(q) {
        document.getElementById('userInput').value = q;
        sendMessage();
    }

    function sendMessage() {
        var input = document.getElementById('userInput');
        var msg = input.value.trim();
        if (!msg) return;

        // Add user message
        appendMessage(msg, 'user');
        input.value = '';

        // Show typing indicator
        var typingId = 'typing_' + Date.now();
        appendTyping(typingId);

        // Scroll down
        scrollChat();

        // Disable send button
        document.getElementById('sendBtn').disabled = true;

        // Call API
        callFitBotAPI(msg, typingId);
    }

    async function callFitBotAPI(userMsg, typingId) {
        var systemPrompt = `Tu FitBot hai — ek expert AI fitness coach jo MegaFitness Pro gym app ka part hai. Tu Hindi aur Hinglish mein baat karta hai (Hindi + English mix). Tu friendly, motivating aur practical hai.

User ki details:
- Naam: ${userName}
- Weight: ${userWeight} kg
- BMI: ${userBMI} (${bmiCategory} category)
- Gym visits: ${userVisits} total
- Membership: ${planStatus}

Rules:
- HAMESHA short aur actionable advice de (max 150 words)
- Bullet points use kar where applicable
- Emojis use kar to make it engaging 💪🔥
- Indian context mein advice de (Indian food, exercises)
- Motivating tone rakh
- Agar BMI data available hai toh personalized advice de`;

        try {
            var response = await fetch("/AI/Chat", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ userMessage: userMsg, systemPrompt: systemPrompt })
            });

            var data = await response.json();

            // Remove typing indicator
            var el = document.getElementById(typingId);
            if (el) el.remove();

            if (!response.ok) {
                appendMessage("⚠️ " + (data.error || "Server error. Dobara try karo!"), 'bot');
            } else {
                appendMessage(data.reply || "Sorry, kuch error aa gayi. Dobara try karo!", 'bot');
            }
        } catch (e) {
            var el = document.getElementById(typingId);
            if (el) el.remove();
            appendMessage("⚠️ Server se connect nahi ho paya. App chal rahi hai? Dobara try karo.", 'bot');
        }

        document.getElementById('sendBtn').disabled = false;
        scrollChat();
    }

    function appendMessage(text, sender) {
        var chatArea = document.getElementById('chatArea');
        var time = new Date().toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit'});

        if (sender === 'user') {
            chatArea.innerHTML += `
            <div class="d-flex flex-column align-items-end mb-4">
                <div style="background:linear-gradient(135deg,#f39c12,#e67e22);color:#111;border-radius:14px 14px 4px 14px;padding:12px 16px;max-width:75%">
                    ${escapeHtml(text)}
                </div>
                <small class="text-muted me-1 mt-1" style="font-size:.7rem">You · ${time}</small>
            </div>`;
        } else {
            var formatted = formatBotMessage(text);
            chatArea.innerHTML += `
            <div class="d-flex align-items-start mb-4">
                <div style="width:36px;height:36px;background:linear-gradient(135deg,#f39c12,#e67e22);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                    <i class="fas fa-robot" style="color:#1a1a1a" style="font-size:.8rem"></i>
                </div>
                <div class="ms-3" style="max-width:80%">
                    <div style="background:#1a1a2e;border:1px solid #2a2a4a;border-radius:14px 14px 14px 4px;padding:14px 18px;line-height:1.7">
                        ${formatted}
                    </div>
                    <small class="text-muted ms-2 mt-1" style="font-size:.7rem">FitBot · ${time}</small>
                </div>
            </div>`;
        }
        scrollChat();
    }

    function appendTyping(id) {
        var chatArea = document.getElementById('chatArea');
        chatArea.innerHTML += `
        <div id="${id}" class="d-flex align-items-start mb-4">
            <div style="width:36px;height:36px;background:linear-gradient(135deg,#f39c12,#e67e22);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                <i class="fas fa-robot" style="color:#1a1a1a" style="font-size:.8rem"></i>
            </div>
            <div class="ms-3">
                <div style="background:#1a1a2e;border:1px solid #2a2a4a;border-radius:14px 14px 14px 4px;padding:14px 18px;">
                    <div class="d-flex gap-1 align-items-center">
                        <span style="width:8px;height:8px;background:#f39c12;border-radius:50%;animation:bounce 1s infinite"></span>
                        <span style="width:8px;height:8px;background:#f39c12;border-radius:50%;animation:bounce 1s .2s infinite"></span>
                        <span style="width:8px;height:8px;background:#f39c12;border-radius:50%;animation:bounce 1s .4s infinite"></span>
                        <span class="ms-2 text-muted small">FitBot soch raha hai...</span>
                    </div>
                </div>
            </div>
        </div>`;
        scrollChat();
    }

    function formatBotMessage(text) {
        text = escapeHtml(text);
        // Bold **text**
        text = text.replace(/\*\*(.*?)\*\*/g, '<strong style="color:#f39c12">$1</strong>');
        // Bullet points
        text = text.replace(/^[-•]\s(.+)/gm, '<div class="d-flex gap-2 mb-1"><span style="color:#f39c12">▸</span><span>$1</span></div>');
        // Numbered lists
        text = text.replace(/^\d+\.\s(.+)/gm, '<div class="d-flex gap-2 mb-1"><span style="color:#f39c12">•</span><span>$1</span></div>');
        // New lines
        text = text.replace(/\n\n/g, '<br><br>').replace(/\n/g, '<br>');
        return text;
    }

    function escapeHtml(text) {
        return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function scrollChat() {
        var c = document.getElementById('chatArea');
        c.scrollTop = c.scrollHeight;
    }
</script>
<style>
    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
    }
</style>
}
