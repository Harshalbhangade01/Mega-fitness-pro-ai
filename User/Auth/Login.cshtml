@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>Login – MegaFitness Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet"/>
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{background:#08080f;color:#e8e8f0;min-height:100vh;display:flex;align-items:center;justify-content:center;font-family:'Nunito','Segoe UI',sans-serif;padding:1.5rem;position:relative;overflow:hidden}

        /* Decorative background orbs */
        .bg-orb{position:fixed;border-radius:50%;pointer-events:none;z-index:0}
        .bg-orb-1{width:500px;height:500px;top:-150px;right:-150px;background:radial-gradient(circle,rgba(243,156,18,0.06) 0%,transparent 70%)}
        .bg-orb-2{width:400px;height:400px;bottom:-100px;left:-100px;background:radial-gradient(circle,rgba(230,126,34,0.05) 0%,transparent 70%)}
        .bg-orb-3{width:2px;height:100vh;top:0;left:50%;background:linear-gradient(to bottom,transparent,rgba(243,156,18,0.04),transparent);transform:translateX(-50%)}

        /* Floating particles */
        .particle{position:fixed;border-radius:50%;pointer-events:none;z-index:0;animation:float linear infinite}
        @@keyframes float{0%{transform:translateY(100vh) rotate(0deg);opacity:0}10%{opacity:.4}90%{opacity:.2}100%{transform:translateY(-100px) rotate(720deg);opacity:0}}

        .page-wrapper{position:relative;z-index:1;width:100%;max-width:460px}

        /* Left accent line on card */
        .login-card{background:#10101c;border:1px solid rgba(243,156,18,0.12);border-radius:24px;padding:2.25rem 2.25rem 2rem;box-shadow:0 40px 80px rgba(0,0,0,0.7),inset 0 1px 0 rgba(255,255,255,0.04);position:relative;overflow:hidden}
        .login-card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:linear-gradient(to bottom,transparent,#f39c12,#e67e22,transparent);border-radius:24px 0 0 24px}

        /* Brand */
        .brand-header{text-align:center;margin-bottom:2rem}
        .brand-logo-wrap{display:inline-flex;align-items:center;justify-content:center;width:72px;height:72px;border-radius:20px;background:linear-gradient(135deg,#1a1206,#2a1a04);border:1.5px solid rgba(243,156,18,0.3);margin-bottom:1rem;position:relative}
        .brand-logo-wrap::after{content:'';position:absolute;inset:-1px;border-radius:20px;background:linear-gradient(135deg,rgba(243,156,18,0.2),transparent);pointer-events:none}
        .brand-logo-wrap i{font-size:1.75rem;color:#f39c12}
        .brand-name{font-size:1.85rem;font-weight:900;color:#ffffff;letter-spacing:-0.8px;margin-bottom:2px}
        .brand-name span{color:#f39c12}
        .brand-tagline{font-size:.875rem;color:#a0a0b8;font-weight:600}

        /* Admin badge */
        .admin-badge{background:rgba(243,156,18,0.08);border:1px solid rgba(243,156,18,0.2);border-radius:12px;padding:11px 14px;margin-bottom:1.5rem;font-size:.78rem;display:flex;gap:10px;align-items:center;color:#c0c0d4}
        .admin-badge strong{color:#f5a623;font-weight:700}
        .admin-badge .badge-icon{width:28px;height:28px;background:rgba(243,156,18,0.15);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .admin-badge .badge-icon i{color:#f39c12;font-size:.75rem}

        /* Field labels */
        .field-group{margin-bottom:1.2rem}
        .field-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:7px}
        .field-label{font-size:.7rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:#9090a8}
        .forgot-link{font-size:.75rem;color:#f39c12;text-decoration:none;font-weight:700;transition:opacity .2s}
        .forgot-link:hover{opacity:.7;color:#f39c12;text-decoration:none}

        /* Inputs */
        .input-wrap{position:relative}
        .input-icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#5a5a78;font-size:.85rem;pointer-events:none;transition:color .2s}
        .form-input{width:100%;background:#0c0c1a;border:1px solid rgba(255,255,255,0.08);color:#e8e8f0;border-radius:12px;padding:13px 14px 13px 42px;font-size:.9rem;outline:none;transition:border-color .25s,box-shadow .25s;font-family:'Nunito',sans-serif;font-weight:600}
        .form-input::placeholder{color:#4a4a68;font-weight:400}
        .form-input:focus{border-color:rgba(243,156,18,0.5);box-shadow:0 0 0 3px rgba(243,156,18,0.08)}
        .form-input:focus + .input-icon, .input-wrap:focus-within .input-icon{color:#f39c12}
        .pw-toggle{position:absolute;right:13px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#5a5a78;font-size:.85rem;padding:5px;transition:color .2s;line-height:1}
        .pw-toggle:hover{color:#c0c0d4}

        /* Error */
        .alert-error{background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);border-radius:12px;padding:12px 14px;margin-bottom:1.25rem;font-size:.85rem;color:#fca5a5;display:flex;gap:10px;align-items:center}
        .alert-error i{color:#f87171;flex-shrink:0}

        /* Submit button */
        .btn-signin{width:100%;background:linear-gradient(135deg,#f39c12 0%,#e67e22 100%);border:none;border-radius:12px;padding:14px;font-size:.95rem;font-weight:800;color:#0a0600;cursor:pointer;letter-spacing:.02em;transition:transform .2s,box-shadow .2s;display:flex;align-items:center;justify-content:center;gap:9px;margin-bottom:1.5rem;font-family:'Nunito',sans-serif;position:relative;overflow:hidden}
        .btn-signin::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.12),transparent);opacity:0;transition:opacity .2s}
        .btn-signin:hover{transform:translateY(-2px);box-shadow:0 15px 35px rgba(243,156,18,0.4)}
        .btn-signin:hover::before{opacity:1}
        .btn-signin:active{transform:scale(.98);box-shadow:none}

        /* Divider */
        .or-divider{display:flex;align-items:center;gap:14px;margin-bottom:1.25rem}
        .or-divider::before,.or-divider::after{content:'';flex:1;height:1px;background:rgba(255,255,255,0.07)}
        .or-divider span{font-size:.72rem;font-weight:700;color:#6a6a88;letter-spacing:.06em;white-space:nowrap;text-transform:uppercase}

        /* Social */
        .social-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:1.5rem}
        .btn-social{background:#0c0c1a;border:1px solid rgba(255,255,255,0.08);color:#c8c8e0;border-radius:12px;padding:11px;font-size:.82rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:border-color .2s,background .2s,color .2s;font-family:'Nunito',sans-serif}
        .btn-social:hover{border-color:rgba(255,255,255,0.2);background:#141428;color:#ffffff}

        /* Bottom link */
        .bottom-link{text-align:center;font-size:.84rem;color:#8888a8;font-weight:600}
        .bottom-link a{color:#f39c12;text-decoration:none;font-weight:800}
        .bottom-link a:hover{opacity:.8;text-decoration:none;color:#f39c12}

        /* Footer */
        .page-footer{text-align:center;font-size:.75rem;color:#6060788;margin-top:1.5rem;color:#6868888}

        /* Fixed footer color visibility */
        .page-footer{color:#7878a0}
        .page-footer a{color:#9898b8;text-decoration:none;transition:color .2s}
        .page-footer a:hover{color:#c8c8e0}

        /* Pulse ring on logo */
        @@keyframes pulse-ring{0%{transform:scale(1);opacity:.5}100%{transform:scale(1.3);opacity:0}}
        .brand-logo-wrap:hover::before{content:'';position:absolute;inset:-6px;border-radius:26px;border:1.5px solid rgba(243,156,18,0.3);animation:pulse-ring .6s ease-out forwards}
    </style>
</head>
<body>
<div class="bg-orb bg-orb-1"></div>
<div class="bg-orb bg-orb-2"></div>
<div class="bg-orb bg-orb-3"></div>

<!-- Floating particles -->
<div class="particle" style="width:3px;height:3px;background:#f39c12;left:15%;animation-duration:8s;animation-delay:0s"></div>
<div class="particle" style="width:2px;height:2px;background:#e67e22;left:35%;animation-duration:11s;animation-delay:3s"></div>
<div class="particle" style="width:4px;height:4px;background:#f39c12;left:65%;animation-duration:9s;animation-delay:1s"></div>
<div class="particle" style="width:2px;height:2px;background:#fbbf24;left:80%;animation-duration:13s;animation-delay:5s"></div>
<div class="particle" style="width:3px;height:3px;background:#e67e22;left:50%;animation-duration:10s;animation-delay:2s"></div>

<div class="page-wrapper">
    <!-- Brand -->
    <div class="brand-header">
        <div class="brand-logo-wrap"><i class="fas fa-dumbbell"></i></div>
        <h1 class="brand-name">Mega<span>Fitness</span> Pro</h1>
        <p class="brand-tagline">Your fitness journey starts here</p>
    </div>

    <div class="login-card">
        <!-- Admin hint -->
        <div class="admin-badge">
            <div class="badge-icon"><i class="fas fa-shield-halved"></i></div>
            <span><strong>Admin:</strong> admin@fitness.com &nbsp;/&nbsp; admin123</span>
        </div>

        @if(ViewBag.Error != null){
            <div class="alert-error">
                <i class="fas fa-circle-exclamation"></i>
                @ViewBag.Error
            </div>
        }

        <form method="post">
            <div class="field-group">
                <div class="field-header">
                    <label class="field-label">Email Address</label>
                </div>
                <div class="input-wrap">
                    <i class="fas fa-envelope input-icon"></i>
                    <input type="email" name="email" class="form-input" placeholder="you@example.com" required/>
                </div>
            </div>

            <div class="field-group" style="margin-bottom:1.75rem">
                <div class="field-header">
                    <label class="field-label">Password</label>
                    <a href="#" class="forgot-link">Forgot password?</a>
                </div>
                <div class="input-wrap">
                    <i class="fas fa-lock input-icon"></i>
                    <input type="password" name="password" id="pwLogin" class="form-input" style="padding-right:44px" placeholder="Enter your password" required/>
                    <button type="button" class="pw-toggle" onclick="var f=document.getElementById('pwLogin');f.type=f.type==='password'?'text':'password';this.querySelector('i').classList.toggle('fa-eye');this.querySelector('i').classList.toggle('fa-eye-slash')">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn-signin">
                <i class="fas fa-right-to-bracket"></i> Sign In to Dashboard
            </button>
        </form>

        <p class="bottom-link">New to MegaFitness? <a href="/Auth/Register">Create free account</a></p>
    </div>

    <p class="page-footer">
        © 2026 MegaFitness Pro &nbsp;·&nbsp;
        <a href="#">Privacy Policy</a> &nbsp;·&nbsp;
        <a href="#">Terms of Service</a>
    </p>
</div>
</body>
</html>
