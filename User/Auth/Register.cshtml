@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>Register – MegaFitness Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet"/>
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{background:#08080f;color:#e8e8f0;min-height:100vh;display:flex;align-items:center;justify-content:center;font-family:'Nunito','Segoe UI',sans-serif;padding:1.5rem;position:relative;overflow:hidden}

        .bg-orb{position:fixed;border-radius:50%;pointer-events:none;z-index:0}
        .bg-orb-1{width:500px;height:500px;top:-150px;left:-150px;background:radial-gradient(circle,rgba(243,156,18,0.06) 0%,transparent 70%)}
        .bg-orb-2{width:400px;height:400px;bottom:-100px;right:-100px;background:radial-gradient(circle,rgba(230,126,34,0.05) 0%,transparent 70%)}

        .particle{position:fixed;border-radius:50%;pointer-events:none;z-index:0;animation:float linear infinite}
        @@keyframes float{0%{transform:translateY(100vh) rotate(0deg);opacity:0}10%{opacity:.4}90%{opacity:.2}100%{transform:translateY(-100px) rotate(720deg);opacity:0}}

        .page-wrapper{position:relative;z-index:1;width:100%;max-width:480px}

        /* Card with right accent */
        .reg-card{background:#10101c;border:1px solid rgba(243,156,18,0.12);border-radius:24px;padding:2.25rem 2.25rem 2rem;box-shadow:0 40px 80px rgba(0,0,0,0.7),inset 0 1px 0 rgba(255,255,255,0.04);position:relative;overflow:hidden}
        .reg-card::before{content:'';position:absolute;top:0;right:0;width:3px;height:100%;background:linear-gradient(to bottom,transparent,#f39c12,#e67e22,transparent);border-radius:0 24px 24px 0}

        /* Brand */
        .brand-header{text-align:center;margin-bottom:2rem}
        .brand-logo-wrap{display:inline-flex;align-items:center;justify-content:center;width:72px;height:72px;border-radius:20px;background:linear-gradient(135deg,#1a1206,#2a1a04);border:1.5px solid rgba(243,156,18,0.3);margin-bottom:1rem;position:relative}
        .brand-logo-wrap::after{content:'';position:absolute;inset:-1px;border-radius:20px;background:linear-gradient(135deg,rgba(243,156,18,0.15),transparent);pointer-events:none}
        .brand-logo-wrap i{font-size:1.75rem;color:#f39c12}
        .brand-name{font-size:1.85rem;font-weight:900;color:#ffffff;letter-spacing:-0.8px;margin-bottom:2px}
        .brand-name span{color:#f39c12}
        .brand-tagline{font-size:.875rem;color:#a0a0b8;font-weight:600}

        /* Progress steps */
        .steps-bar{display:flex;align-items:center;justify-content:center;gap:0;margin-bottom:1.75rem}
        .step{display:flex;align-items:center;gap:0}
        .step-dot{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:800;transition:.3s}
        .step-dot.active{background:linear-gradient(135deg,#f39c12,#e67e22);color:#0a0600;box-shadow:0 4px 14px rgba(243,156,18,0.4)}
        .step-dot.done{background:rgba(243,156,18,0.2);color:#f39c12;border:1.5px solid rgba(243,156,18,0.4)}
        .step-dot.pending{background:rgba(255,255,255,0.05);color:#5a5a78;border:1.5px solid rgba(255,255,255,0.08)}
        .step-label{font-size:.65rem;font-weight:700;color:#7878a0;text-align:center;margin-top:5px;letter-spacing:.05em}
        .step-item{display:flex;flex-direction:column;align-items:center;gap:0}
        .step-line{width:48px;height:1px;background:rgba(255,255,255,0.07);margin-bottom:22px}
        .step-line.done{background:rgba(243,156,18,0.3)}

        /* Fields */
        .fields-grid{display:grid;grid-template-columns:1fr 1fr;gap:0 14px}
        .field-group{margin-bottom:1.15rem}
        .field-group.full{grid-column:1/-1}
        .field-label{display:block;font-size:.7rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:#9090a8;margin-bottom:7px}

        .input-wrap{position:relative}
        .input-icon{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:#5a5a78;font-size:.82rem;pointer-events:none;transition:color .2s}
        .form-input{width:100%;background:#0c0c1a;border:1px solid rgba(255,255,255,0.08);color:#e8e8f0;border-radius:12px;padding:12px 13px 12px 38px;font-size:.88rem;outline:none;transition:border-color .25s,box-shadow .25s;font-family:'Nunito',sans-serif;font-weight:600}
        .form-input::placeholder{color:#4a4a68;font-weight:400}
        .form-input:focus{border-color:rgba(243,156,18,0.5);box-shadow:0 0 0 3px rgba(243,156,18,0.08)}
        .form-input:focus ~ .input-icon,.input-wrap:focus-within .input-icon{color:#f39c12}
        .pw-toggle{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#5a5a78;font-size:.82rem;padding:4px;transition:color .2s}
        .pw-toggle:hover{color:#c0c0d4}

        /* Password strength bar */
        .pw-strength{height:3px;border-radius:2px;margin-top:7px;background:rgba(255,255,255,0.06);overflow:hidden;display:none}
        .pw-strength-fill{height:100%;border-radius:2px;transition:width .3s,background .3s;width:0}
        .pw-strength-label{font-size:.68rem;color:#7878a0;margin-top:5px;font-weight:600;display:none}

        /* Terms checkbox */
        .terms-row{display:flex;align-items:flex-start;gap:10px;margin-bottom:1.5rem}
        .terms-checkbox{width:16px;height:16px;accent-color:#f39c12;flex-shrink:0;margin-top:2px;cursor:pointer}
        .terms-text{font-size:.78rem;color:#8888a8;font-weight:600;line-height:1.5}
        .terms-text a{color:#f39c12;text-decoration:none;font-weight:700}
        .terms-text a:hover{opacity:.8}

        /* Error */
        .alert-error{background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);border-radius:12px;padding:12px 14px;margin-bottom:1.25rem;font-size:.85rem;color:#fca5a5;display:flex;gap:10px;align-items:center}
        .alert-error i{color:#f87171;flex-shrink:0}

        /* Submit */
        .btn-register{width:100%;background:linear-gradient(135deg,#f39c12 0%,#e67e22 100%);border:none;border-radius:12px;padding:14px;font-size:.95rem;font-weight:800;color:#0a0600;cursor:pointer;letter-spacing:.02em;transition:transform .2s,box-shadow .2s;display:flex;align-items:center;justify-content:center;gap:9px;margin-bottom:1.25rem;font-family:'Nunito',sans-serif;position:relative;overflow:hidden}
        .btn-register::before{content:'';position:absolute;inset:0;background:rgba(255,255,255,0.1);opacity:0;transition:opacity .2s}
        .btn-register:hover{transform:translateY(-2px);box-shadow:0 15px 35px rgba(243,156,18,0.4)}
        .btn-register:hover::before{opacity:1}
        .btn-register:active{transform:scale(.98);box-shadow:none}

        /* Benefits strip */
        .benefits{display:flex;justify-content:center;gap:20px;margin-bottom:1.5rem}
        .benefit{display:flex;align-items:center;gap:5px;font-size:.72rem;color:#7878a0;font-weight:700}
        .benefit i{color:#f39c12;font-size:.7rem}

        .bottom-link{text-align:center;font-size:.84rem;color:#8888a8;font-weight:600}
        .bottom-link a{color:#f39c12;text-decoration:none;font-weight:800}
        .bottom-link a:hover{opacity:.8}

        .page-footer{text-align:center;font-size:.75rem;color:#7878a0;margin-top:1.5rem}
        .page-footer a{color:#9898b8;text-decoration:none;transition:color .2s}
        .page-footer a:hover{color:#c8c8e0}
    </style>
</head>
<body>
<div class="bg-orb bg-orb-1"></div>
<div class="bg-orb bg-orb-2"></div>
<div class="particle" style="width:3px;height:3px;background:#f39c12;left:20%;animation-duration:9s;animation-delay:1s"></div>
<div class="particle" style="width:2px;height:2px;background:#e67e22;left:55%;animation-duration:12s;animation-delay:4s"></div>
<div class="particle" style="width:4px;height:4px;background:#fbbf24;left:75%;animation-duration:8s;animation-delay:0s"></div>
<div class="particle" style="width:2px;height:2px;background:#f39c12;left:40%;animation-duration:14s;animation-delay:6s"></div>

<div class="page-wrapper">
    <div class="brand-header">
        <div class="brand-logo-wrap"><i class="fas fa-dumbbell"></i></div>
        <h1 class="brand-name">Mega<span>Fitness</span> Pro</h1>
        <p class="brand-tagline">Join 10,000+ members transforming their lives</p>
    </div>

    <div class="reg-card">
        <!-- Progress steps -->
        <div class="steps-bar">
            <div class="step-item">
                <div class="step-dot active">1</div>
                <div class="step-label">Account</div>
            </div>
            <div class="step-line"></div>
            <div class="step-item">
                <div class="step-dot pending">2</div>
                <div class="step-label">Profile</div>
            </div>
            <div class="step-line"></div>
            <div class="step-item">
                <div class="step-dot pending">3</div>
                <div class="step-label">Goals</div>
            </div>
        </div>

        @if(ViewBag.Error != null){
            <div class="alert-error">
                <i class="fas fa-circle-exclamation"></i>
                @ViewBag.Error
            </div>
        }

        <!-- Benefits strip -->
        <div class="benefits">
            <div class="benefit"><i class="fas fa-check-circle"></i> Free forever</div>
            <div class="benefit"><i class="fas fa-check-circle"></i> No credit card</div>
            <div class="benefit"><i class="fas fa-check-circle"></i> Cancel anytime</div>
        </div>

        <form method="post">
            <div class="fields-grid">
                <!-- Full Name -->
                <div class="field-group full">
                    <label class="field-label">Full Name</label>
                    <div class="input-wrap">
                        <i class="fas fa-user input-icon"></i>
                        <input type="text" name="Name" class="form-input" placeholder="John Doe" required/>
                    </div>
                </div>

                <!-- Email -->
                <div class="field-group full">
                    <label class="field-label">Email Address</label>
                    <div class="input-wrap">
                        <i class="fas fa-envelope input-icon"></i>
                        <input type="email" name="Email" class="form-input" placeholder="you@example.com" required/>
                    </div>
                </div>

                <!-- Phone -->
                <div class="field-group full">
                    <label class="field-label">Phone Number</label>
                    <div class="input-wrap">
                        <i class="fas fa-phone input-icon"></i>
                        <input type="text" name="Phone" class="form-input" placeholder="9876543210"/>
                    </div>
                </div>

                <!-- Password -->
                <div class="field-group full">
                    <label class="field-label">Password</label>
                    <div class="input-wrap">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="Password" id="pwReg" class="form-input" style="padding-right:44px" placeholder="Minimum 6 characters" required oninput="checkPwStrength(this.value)"/>
                        <button type="button" class="pw-toggle" onclick="var f=document.getElementById('pwReg');f.type=f.type==='password'?'text':'password';this.querySelector('i').classList.toggle('fa-eye');this.querySelector('i').classList.toggle('fa-eye-slash')">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <div class="pw-strength" id="pwBar"><div class="pw-strength-fill" id="pwFill"></div></div>
                    <div class="pw-strength-label" id="pwLabel"></div>
                </div>
            </div>

            <!-- Terms -->
            <div class="terms-row">
                <input type="checkbox" class="terms-checkbox" id="terms" required/>
                <label for="terms" class="terms-text">
                    I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>. I'm ready to start my fitness journey!
                </label>
            </div>

            <button type="submit" class="btn-register">
                <i class="fas fa-rocket"></i> Create My Account
            </button>
        </form>

        <p class="bottom-link">Already have an account? <a href="/Auth/Login">Sign in here</a></p>
    </div>

    <p class="page-footer">
        © 2026 MegaFitness Pro &nbsp;·&nbsp;
        <a href="#">Privacy Policy</a> &nbsp;·&nbsp;
        <a href="#">Terms of Service</a>
    </p>
</div>

<script>
function checkPwStrength(val){
    var bar=document.getElementById('pwBar');
    var fill=document.getElementById('pwFill');
    var label=document.getElementById('pwLabel');
    if(!val){bar.style.display='none';label.style.display='none';return}
    bar.style.display='block';label.style.display='block';
    var score=0;
    if(val.length>=6)score++;
    if(val.length>=10)score++;
    if(/[A-Z]/.test(val))score++;
    if(/[0-9]/.test(val))score++;
    if(/[^A-Za-z0-9]/.test(val))score++;
    var pct=['20%','40%','60%','80%','100%'][score-1]||'10%';
    var clr=['#ef4444','#f97316','#eab308','#22c55e','#10b981'][score-1]||'#ef4444';
    var txt=['Too weak','Weak','Fair','Strong','Very strong'][score-1]||'Too weak';
    fill.style.width=pct;fill.style.background=clr;
    label.textContent=txt;label.style.color=clr;
}
</script>
</body>
</html>
